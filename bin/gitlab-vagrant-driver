#!/bin/sh
set -e

test -n "$VAGRANT_DRIVER_DEBUG" && set -x

vagrant_driver_version=0.0.2

BUILD_FAILURE_EXIT_CODE=${BUILD_FAILURE_EXIT_CODE:-1}
SYSTEM_FAILURE_EXIT_CODE=${SYSTEM_FAILURE_EXIT_CODE:-2}

stage="$1" && shift || true
test -n "$stage" || {
	echo "missing required argument stage" >&2
	exit "$SYSTEM_FAILURE_EXIT_CODE"
}

config() {
	while [ $# -gt 0 ]; do
		case "$1" in
		image=*)
			image=${1#image=}
			;;
		provider=*)
			provider=${1#provider=}
			;;
		template=*)
			template=${1#template=}
			;;
		*)
			echo "unknown config parameter $1" >&2
			exit "$SYSTEM_FAILURE_EXIT_CODE"
			;;
		esac
		shift
	done
	test -n "$image" || {
		echo "missing required parameter image" >&2
		exit "$SYSTEM_FAILURE_EXIT_CODE"
	}
	image="${CUSTOM_ENV_JOB_IMAGE:-$image}"
	case "$image" in
	*"windows"*)
		shell="powershell"
		communicator="winrm"
		temp="C:/temp"
		;;
	*"macos"*)
		shell="sh"
		communicator="ssh"
		temp="/tmp"
		;;
	*)
		echo "unsupported guest os for image $image" >&2
		exit "$SYSTEM_FAILURE_EXIT_CODE"
		;;
	esac
	test -n "$VAGRANT_DRIVER_DEBUG" && cat >driver.env <<EOF
provider=$provider
template=$template
image=$image
communicator=$communicator
temp=$temp
EOF
	cat <<EOF
{
  "driver": {
    "name": "vagrant",
    "version": "$vagrant_driver_version"
  },
  "shell": "$shell",
  "job_env": {
	"provider": "$provider",
	"template": "$template",
	"image": "$image",
	"communicator": "$communicator",
	"temp": "$temp"
  }
}
EOF
}

prepare() {
	# shellcheck source=/dev/null
	test -n "$VAGRANT_DRIVER_DEBUG" && . "driver.env"
	box_name=$(echo "$image" | cut -d ':' -f 1)
	if [ "$box_name" != "$image" ]; then
		box_version=$(echo "$image" | cut -d ':' -f 2)
		version_args="--box-version $box_version"
	fi
	test -n "$provider" && provider_args="--provider $provider"
	test -n "$template" && template_args="--template $template"
	# shellcheck disable=SC2086
	vagrant init $version_args $template_args "$box_name" --force || {
		echo "failed to initialize Vagrant environment" >&2
		exit "$SYSTEM_FAILURE_EXIT_CODE"
	}
	# shellcheck disable=SC2086
	vagrant up $provider_args || {
		echo "failed to start Vagrant environment" >&2
		exit "$SYSTEM_FAILURE_EXIT_CODE"
	}
}

run() {
	# shellcheck source=/dev/null
	test -n "$VAGRANT_DRIVER_DEBUG" && . "driver.env"
	script="$1" && shift || true
	test -n "$script" || {
		echo "missing required argument script" >&2
		exit "$SYSTEM_FAILURE_EXIT_CODE"
	}
	script_name=$(basename "$script")
	description="$1" && shift || true
	test -n "$description" || {
		echo "missing required argument description" >&2
		exit "$SYSTEM_FAILURE_EXIT_CODE"
	}
	test -n "$description" && echo "$description"
	vagrant upload "$script" "$temp/$script_name" >/dev/null 2>&1 || {
		echo "failed to upload script $description" >&2
		exit "$SYSTEM_FAILURE_EXIT_CODE"
	}
	vagrant "$communicator" --command "$temp/$script_name" || {
		echo $? >"$BUILD_EXIT_CODE_FILE"
		echo "failed to execute script $description" >&2
		exit "$BUILD_FAILURE_EXIT_CODE"
	}
}

cleanup() {
	test -f Vagrantfile && (vagrant destroy --force || vagrant destroy --force || {
		echo "failed to destroy Vagrant environment" >&2
		exit "$SYSTEM_FAILURE_EXIT_CODE"
	})
}

case "$stage" in
config | prepare | run | cleanup)
	"$stage" "$@"
	;;
help)
	echo "version $vagrant_driver_version"
	echo "usage: $0 <stage> [args...]"
	;;
*)
	echo "unknown stage $stage" >&2
	exit "$SYSTEM_FAILURE_EXIT_CODE"
	;;
esac
